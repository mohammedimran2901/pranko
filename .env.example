# ─── Fal.ai for image / video generation ──────────────────────────────
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# ─── Polar payments (https://polar.sh) ────────────────────────────────
# 1. Create an account at https://polar.sh and finish onboarding.
# 2. Create an Organization (the dashboard will give you an ID).
# 3. Create a "Product" in Polar with:
#      - Recurring billing, weekly interval
#      - Price: $4.99 USD
#      - Name: "Pranko Weekly"
#      - Description: "6 prank video credits per week"
# 4. In Settings → Developers, create an Access Token (polar_oat_***).
# 5. In Settings → Developers → Webhooks, add endpoint:
#      https://<your-domain>/api/polar/webhook
#    Subscribe to: subscription.created, subscription.active,
#                  subscription.updated, subscription.canceled,
#                  subscription.revoked, checkout.updated.
#    Copy the webhook secret (whsec_*** or similar).
# 6. Paste values below.
POLAR_ACCESS_TOKEN=polar_oat_xxxxxxxxxxxxxxxx
POLAR_ORGANIZATION_ID=org_xxxxxxxxxxxxxxxx
POLAR_WEEKLY_PRODUCT_ID=prod_xxxxxxxxxxxxxxxx
POLAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Use "sandbox" while testing, "production" when going live.
POLAR_SERVER=sandbox

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://pranko.app
NEXT_PUBLIC_APP_NAME=Pranko

# ─── Optional: Supabase (for storing job history & user accounts) ───
# Not required for launch — the in-memory store handles credits and jobs.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
